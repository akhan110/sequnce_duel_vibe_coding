rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validating requests
    function isSignedIn() {
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /games/{gameId} {
      // Allow any user to fetch games (guests & google users alike)
      allow get: if isValidId(gameId);
      
      // Allow list of games that are currently waiting for players (Lobby Matchmaking)
      allow list: if true;

      // Create game: only requires valid id and waiting status
      allow create: if isValidId(gameId)
        && incoming().status == "waiting"
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Update game: Allows any client to write updates
      allow update: if incoming().updatedAt == request.time;

      // Deletion is forbidden to keep standard state integrity
      allow delete: if false;
    }
  }
}
